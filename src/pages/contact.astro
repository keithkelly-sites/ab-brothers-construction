---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact - AB Brothers Construction"
  description="Get in touch with AB Brothers Construction for expert home remodeling, renovation, and construction services in Pittsburgh's South Hills. Free consultation and quote."
>

  <!-- Hero -->
  <section class="bg-primary py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-3">Get in Touch</p>
      <h1 class="text-primary-foreground max-w-2xl">Contact Us</h1>
      <p class="text-primary-foreground/70 mt-4 max-w-xl text-lg">
        We'd love to hear about your project. Reach out for a free consultation and quote.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <h2 class="mb-6">Reach Out Directly</h2>
          <p class="text-muted-foreground leading-relaxed mb-8">
            AB Brothers Construction is a South Hills based residential general contractor committed to craftsmanship and quality, specializing in kitchen and bathroom remodels, additions, and home alterations.
          </p>

          <div class="space-y-6">
            <div>
              <p class="text-xs uppercase tracking-widest text-muted-foreground font-semibold mb-2">Andy Hovanec</p>
              <a href="tel:4128551849" class="flex items-center gap-3 text-foreground font-medium opacity-100 hover:text-accent">
                <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                (412) 855-1849
              </a>
            </div>

            <div>
              <p class="text-xs uppercase tracking-widest text-muted-foreground font-semibold mb-2">Bob Krapp</p>
              <a href="tel:4126208821" class="flex items-center gap-3 text-foreground font-medium opacity-100 hover:text-accent">
                <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                (412) 620-8821
              </a>
            </div>

            <div>
              <p class="text-xs uppercase tracking-widest text-muted-foreground font-semibold mb-2">Email</p>
              <a href="mailto:abconstruction412@yahoo.com" class="flex items-center gap-3 text-foreground font-medium opacity-100 hover:text-accent">
                <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                abconstruction412@yahoo.com
              </a>
            </div>

            <div>
              <p class="text-xs uppercase tracking-widest text-muted-foreground font-semibold mb-2">Location</p>
              <div class="flex items-center gap-3 text-foreground font-medium">
                <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                Venetia, PA (South Hills of Pittsburgh)
              </div>
            </div>
          </div>

          <div class="flex gap-4 mt-8">
            <a href="https://www.facebook.com/AB.BroConstruction/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary opacity-100 hover:bg-primary hover:text-white" aria-label="Facebook">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/andrew-hovanec-88b11231/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary opacity-100 hover:bg-primary hover:text-white" aria-label="LinkedIn">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="bg-white border border-border rounded-md p-8">
            <h3 class="mb-1">Send Us a Message</h3>
            <p class="text-muted-foreground text-sm mb-6">Fill out the form below and we'll get back to you promptly.</p>

            <form id="contact-form" class="space-y-5">
              <div>
                <label for="name" class="block text-sm font-medium mb-1.5">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full border border-border rounded-md px-4 py-3 text-sm bg-background focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                  placeholder="Your name"
                />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="email" class="block text-sm font-medium mb-1.5">Email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full border border-border rounded-md px-4 py-3 text-sm bg-background focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                    placeholder="your@email.com"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium mb-1.5">Phone</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full border border-border rounded-md px-4 py-3 text-sm bg-background focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                    placeholder="(412) 555-0000"
                  />
                </div>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium mb-1.5">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full border border-border rounded-md px-4 py-3 text-sm bg-background focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary resize-none"
                  placeholder="Tell us about your project..."
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full bg-accent text-white font-semibold px-8 py-3.5 rounded-full hover:bg-accent/90 text-sm"
              >
                Send Message
              </button>
            </form>

            <div id="form-success" class="hidden text-center py-12">
              <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h3 class="mb-2">Thanks for reaching out!</h3>
              <p class="text-muted-foreground text-sm">Andy or Bob will get back to you soon.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="bg-muted py-16 md:py-20">
    <div class="max-w-[700px] mx-auto px-6 md:px-12 text-center">
      <blockquote class="border-l-3 border-accent pl-6 text-left">
        <p class="text-foreground/80 leading-relaxed italic text-lg mb-5">
          "Andrew and his crew did an amazing job on my new bathroom remodel! They paid attention to close detail and really listened to all my special requests. They were very professional and neat during the job as well. I would recommend them for sure!"
        </p>
        <footer>
          <cite class="not-italic text-sm font-medium">Christina Spicer</cite>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Map -->
  <section class="py-16 md:py-20">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <h2 class="text-center mb-4">Serving Pittsburgh's South Hills</h2>
      <p class="text-muted-foreground text-center mb-8 text-sm">Venetia, PA and surrounding communities</p>
      <iframe
        title="AB Brothers Construction location on Google Maps"
        src="https://www.google.com/maps?q=Venetia%2C+PA&output=embed"
        width="100%"
        height="400"
        style="border: 0; border-radius: 8px;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form');
    const success = document.getElementById('form-success');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form as HTMLFormElement));
      try {
        await fetch('https://api.keithkelly.dev/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, siteToken: 'ab-brothers-construction' }),
        });
      } catch {
        // Show success regardless
      }
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    });
  </script>

</Layout>
