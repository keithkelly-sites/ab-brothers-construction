---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — AB Brothers Construction"
  description="Get in touch with AB Brothers Construction for a free consultation. Kitchen remodeling, home additions, and renovations in Pittsburgh's South Hills."
>

  <!-- Hero -->
  <section class="hero">
    <img src="/images/bathroom-1200-x-1200-updated.png" alt="" class="hero-bg" aria-hidden="true" fetchpriority="high" />
    <div class="hero-overlay"></div>
    <div class="hero-content wrap">
      <span class="label">Get in Touch</span>
      <h1>Contact Us</h1>
      <p class="hero-sub text-dim">
        Every project starts with a conversation. Reach out for a free consultation.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="contact-section">
    <div class="wrap">
      <div class="contact-grid">

        <!-- Info -->
        <div class="contact-info reveal">
          <h2>Reach Out Directly</h2>
          <p class="text-dim contact-desc">
            AB Brothers Construction is a South Hills based residential general contractor. Kitchen and bathroom remodels, additions, and home alterations.
          </p>

          <address class="contact-items">
            <div class="contact-item">
              <span class="contact-label label">Andy Hovanec</span>
              <a href="tel:4128551849" class="contact-value">(412) 855-1849</a>
            </div>
            <div class="contact-item">
              <span class="contact-label label">Bob Krapp</span>
              <a href="tel:4126208821" class="contact-value">(412) 620-8821</a>
            </div>
            <div class="contact-item">
              <span class="contact-label label">Email</span>
              <a href="mailto:abconstruction412@yahoo.com" class="contact-value">abconstruction412@yahoo.com</a>
            </div>
            <div class="contact-item">
              <span class="contact-label label">Location</span>
              <span class="contact-value">South Hills of Pittsburgh</span>
            </div>
          </address>

          <div class="contact-social">
            <a href="https://www.facebook.com/AB.BroConstruction/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              <span>Facebook</span>
            </a>
            <a href="https://www.linkedin.com/in/andrew-hovanec-88b11231/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-link">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span>LinkedIn</span>
            </a>
          </div>
        </div>

        <!-- Form -->
        <div class="contact-form-wrap reveal">
          <form id="contact-form" class="contact-form" action="https://api.keithkelly.dev/contact" method="POST">
            <h3>Send Us a Message</h3>
            <p class="text-dim form-desc">Fill out the form below and we'll get back to you promptly.</p>

            <div class="field">
              <label for="name">Name <span class="required-mark" aria-hidden="true">*</span></label>
              <input type="text" id="name" name="name" required aria-required="true" placeholder="Your name" autocomplete="name" />
            </div>

            <div class="field-row">
              <div class="field">
                <label for="email">Email <span class="required-mark" aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" required aria-required="true" placeholder="your@email.com" autocomplete="email" />
              </div>
              <div class="field">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" placeholder="(412) 555-0000" autocomplete="tel" />
              </div>
            </div>

            <div class="field">
              <label for="message">Message <span class="required-mark" aria-hidden="true">*</span></label>
              <textarea id="message" name="message" rows="5" required aria-required="true" placeholder="Tell us about your project..."></textarea>
            </div>

            <button type="submit" class="btn btn--copper submit-btn">Send Message</button>
          </form>

          <div id="form-success" class="form-success" hidden>
            <div class="success-icon">
              <svg width="32" height="32" fill="none" stroke="var(--copper)" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3>Thanks for reaching out!</h3>
            <p class="text-dim">Andy or Bob will get back to you soon.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="quote-section section--surface">
    <div class="wrap wrap--narrow reveal">
      <blockquote class="pullquote">
        <div class="pullquote-bar"></div>
        <p>
          "Andrew and his crew did an amazing job on my new bathroom remodel! They paid attention to close detail and really listened to all my special requests. Very professional and neat during the job. I would recommend them for sure!"
        </p>
        <footer>
          <cite>Christina Spicer</cite>
        </footer>
      </blockquote>
    </div>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const success = document.getElementById('form-success');
      if (!form || !success) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));
        try {
          await fetch('https://api.keithkelly.dev/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...data, siteToken: 'ab-brothers-construction' }),
          });
        } catch {
          // Show success regardless
        }
        form.hidden = true;
        success.hidden = false;
      });
    });
  </script>

</Layout>

<style>
  .hero {
    position: relative;
    min-height: 45vh;
    display: flex;
    align-items: flex-end;
    padding-block: 6rem 3rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--dark) 30%,
      color-mix(in oklch, var(--dark) 70%, transparent)
    );
  }

  .hero-content { position: relative; z-index: 1; }
  .hero h1 { margin-top: 0.75rem; }

  .hero-sub {
    margin-top: 1rem;
    font-size: 1.125rem;
    max-width: 28rem;
  }

  /* Contact section */
  .contact-section {
    padding-block: var(--section-y);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 2fr 3fr;
      gap: 4rem;
    }
  }

  .contact-info h2 {
    margin-bottom: 1rem;
  }

  .contact-desc {
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-label {
    display: block;
    margin-bottom: 0.25rem;
  }

  .contact-value {
    font-size: 1.0625rem;
    transition: color 0.2s;
  }

  a.contact-value:hover {
    color: var(--copper);
  }

  .contact-social {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--cream-dim);
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .social-link:hover {
    color: var(--copper);
  }

  .required-mark {
    color: var(--copper);
    margin-left: 0.125rem;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--dark-surface);
    border: 1px solid var(--border);
    padding: 2rem;
  }

  @media (min-width: 600px) {
    .contact-form-wrap {
      padding: 2.5rem;
    }
  }

  .contact-form h3 {
    margin-bottom: 0.25rem;
  }

  .form-desc {
    font-size: 0.9375rem;
    margin-bottom: 2rem;
  }

  .field {
    margin-bottom: 1.25rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 500px) {
    .field-row {
      grid-template-columns: 1fr 1fr;

      & .field { margin-bottom: 0; }
    }
  }

  label {
    display: block;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--cream-dim);
  }

  input,
  textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--dark);
    border: 1px solid var(--border);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    transition: border-color 0.2s;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--cream-dim);
    opacity: 0.5;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--copper);
  }

  textarea {
    resize: vertical;
    min-height: 7rem;
  }

  .submit-btn {
    width: 100%;
    margin-top: 0.5rem;
  }

  /* Success */
  .form-success {
    text-align: center;
    padding: 4rem 2rem;
  }

  .success-icon {
    width: 4rem;
    height: 4rem;
    border: 2px solid var(--copper);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .form-success h3 {
    margin-bottom: 0.5rem;
  }

  /* Testimonial */
  .quote-section {
    padding-block: var(--section-y);
  }

  .pullquote {
    position: relative;
    padding-left: 2rem;
  }

  .pullquote-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--copper);
  }

  .pullquote p {
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--cream);
    margin-bottom: 1.25rem;
  }

  .pullquote cite {
    font-style: normal;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8125rem;
    color: var(--copper);
  }
</style>
