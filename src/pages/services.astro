---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Services — AB Brothers Construction"
  description="Kitchen and bathroom remodels, home additions, and home alterations in Pittsburgh's South Hills. Licensed, insured, and built on 12+ years of hands-on experience."
>

  <!-- Hero -->
  <section class="hero">
    <img src="/images/kitchen-and-bath-collage-1.png" alt="" class="hero-bg" aria-hidden="true" fetchpriority="high" />
    <div class="hero-overlay"></div>
    <div class="hero-content wrap">
      <span class="label">Our Services</span>
      <h1>What We Build</h1>
      <p class="hero-sub text-dim">
        Three specialties. One standard: do the work right, every time.
      </p>
    </div>
  </section>

  <!-- Kitchen & Bath -->
  <section id="kitchen-bath" class="service-section">
    <div class="wrap">
      <div class="service-grid">
        <div class="service-text reveal">
          <span class="label">Kitchen & Bath</span>
          <h2>Kitchen & Bathroom Remodeling</h2>
          <p class="text-dim">
            Custom cabinetry, tile work, plumbing, and full renovations. We've spent 12 years turning everyday rooms into the ones you show off to guests. From marble vanity tops to farmhouse sinks, we handle every detail.
          </p>
          <ul class="service-list">
            <li>Custom cabinetry and countertop installation</li>
            <li>Tile work and backsplash design</li>
            <li>Plumbing, electrical, and fixture upgrades</li>
            <li>Handicap accessibility compliance</li>
          </ul>
          <a href="/contact" class="btn btn--copper">Get a Free Quote</a>
        </div>
        <div class="service-images reveal">
          <img src="/images/bathroom-1200-x-1200-updated.png" alt="Freestanding bathtub with marble tile floor" class="service-img service-img--main" loading="lazy" />
          <div class="service-img-pair">
            <img src="/images/11.png" alt="Marble tile bathroom with teal walls" loading="lazy" />
            <img src="/images/33.png" alt="Modern walk-in shower with dark tile" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="copper-rule" />

  <!-- Additions -->
  <section id="additions" class="service-section">
    <div class="wrap">
      <div class="service-grid service-grid--reverse">
        <div class="service-text reveal">
          <span class="label">Additions</span>
          <h2>Home Additions</h2>
          <p class="text-dim">
            New rooms, sunrooms, mud rooms, expanded living areas. We build additions that match your home's character so well, guests won't know what's new and what's original.
          </p>
          <ul class="service-list">
            <li>Room additions and living space expansions</li>
            <li>Mud rooms, sunrooms, and bonus rooms</li>
            <li>Seamless integration with existing structure</li>
          </ul>
          <a href="/contact" class="btn btn--copper">Discuss Your Addition</a>
        </div>
        <div class="service-images reveal">
          <img src="/images/home-additions-pittburgh-pa.png" alt="Kitchen addition with exposed brick and wood ceiling" class="service-img service-img--main" loading="lazy" />
          <div class="service-img-pair">
            <img src="/images/additions-images-1.png" alt="Sunroom addition with wood plank ceiling" loading="lazy" />
            <img src="/images/untitled-design-56.png" alt="Custom staircase with oak and metal railings" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="copper-rule" />

  <!-- Alterations -->
  <section id="alterations" class="service-section">
    <div class="wrap">
      <div class="service-grid">
        <div class="service-text reveal">
          <span class="label">Alterations</span>
          <h2>Home Alterations</h2>
          <p class="text-dim">
            Open-concept conversions, basement finishing, game rooms, complete home renovations. We've gutted 1950s houses down to the studs and turned them into something their owners barely recognize.
          </p>
          <ul class="service-list">
            <li>Open-concept conversions and layout changes</li>
            <li>Basement finishing and game room builds</li>
            <li>Trim, flooring, drywall, and skim-coating</li>
            <li>Water damage repair and restoration</li>
          </ul>
          <a href="/contact" class="btn btn--copper">Start Your Renovation</a>
        </div>
        <div class="service-images reveal">
          <img src="/images/home-alterations-2.png" alt="Open concept living space with stone fireplace" class="service-img service-img--main" loading="lazy" />
          <div class="service-img-pair">
            <img src="/images/37.png" alt="Custom fireplace surround with stone and wood built-ins" loading="lazy" />
            <img src="/images/38.png" alt="Bathroom renovation with glass shower and bathtub" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why AB Brothers -->
  <section class="why-section section--surface">
    <div class="wrap">
      <div class="why-header reveal">
        <span class="label">Why AB Brothers</span>
        <h2>Six Reasons to Call Us First</h2>
      </div>
      <div class="why-grid">
        <div class="why-card reveal">
          <span class="why-number text-copper">01</span>
          <h3>Certified Tradesmen</h3>
          <p class="text-dim">Master plumbers, electricians, tilers. Each team member is thoroughly vetted. No day laborers, no shortcuts.</p>
        </div>
        <div class="why-card reveal">
          <span class="why-number text-copper">02</span>
          <h3>Family-Owned</h3>
          <p class="text-dim">Andy and Bob are on every job. You're not handed off to a crew you've never met.</p>
        </div>
        <div class="why-card reveal">
          <span class="why-number text-copper">03</span>
          <h3>Daily Schedule</h3>
          <p class="text-dim">You get a detailed day-by-day schedule and clear budget before work begins. No surprises.</p>
        </div>
        <div class="why-card reveal">
          <span class="why-number text-copper">04</span>
          <h3>Premium Materials</h3>
          <p class="text-dim">Top-of-the-line building supplies cost a bit more upfront, but our work lasts longer. Your home's value goes up.</p>
        </div>
        <div class="why-card reveal">
          <span class="why-number text-copper">05</span>
          <h3>Built on Referrals</h3>
          <p class="text-dim">Most of our business comes from past clients telling their neighbors. That's the reputation we protect.</p>
        </div>
        <div class="why-card reveal">
          <span class="why-number text-copper">06</span>
          <h3>Licensed & Insured</h3>
          <p class="text-dim">Fully licensed residential general contractor. Every sub we bring in is licensed and insured too.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="wrap" style="text-align: center;">
      <h2 class="reveal">Let's Talk About Your Project</h2>
      <p class="text-dim reveal" style="max-width: 32rem; margin: 1.25rem auto 2rem;">
        Every project starts with a conversation. Call us or fill out our contact form for a free consultation.
      </p>
      <a href="/contact" class="btn btn--copper reveal">Get a Free Quote</a>
    </div>
  </section>

</Layout>

<style>
  .hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
    padding-block: 6rem 3rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--dark) 30%,
      color-mix(in oklch, var(--dark) 75%, transparent)
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    margin-top: 0.75rem;
  }

  .hero-sub {
    margin-top: 1rem;
    font-size: 1.125rem;
    max-width: 28rem;
  }

  /* Service sections */
  .service-section {
    padding-block: var(--section-y);
    scroll-margin-top: 5rem;
  }

  .service-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .service-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .service-grid--reverse .service-text {
      order: 2;
    }
    .service-grid--reverse .service-images {
      order: 1;
    }
  }

  .service-text h2 {
    margin-top: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .service-list {
    margin-top: 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .service-list li {
    padding-left: 1.5rem;
    position: relative;
    font-size: 0.9375rem;
    color: var(--cream-dim);

    &::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.6em;
      width: 0.75rem;
      height: 1px;
      background: var(--copper);
    }
  }

  .service-images {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-img--main {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .service-img-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;

    & img {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
    }
  }

  /* Why section */
  .why-section {
    padding-block: var(--section-y);
  }

  .why-header {
    margin-bottom: 3rem;
  }

  .why-header h2 {
    margin-top: 0.75rem;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .why-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 900px) {
    .why-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .why-card {
    padding: 2rem;
    border: 1px solid var(--border);
    background: var(--dark);
  }

  .why-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 900;
    display: block;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .why-card h3 {
    margin-bottom: 0.75rem;
  }

  .why-card p {
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* CTA */
  .cta-section {
    padding-block: var(--section-y);
  }

  .cta-section h2 {
    margin-bottom: 0.5rem;
  }
</style>
