---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const businessName = 'AB Brothers Construction';
const currentPath = Astro.url.pathname;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/services`, label: 'Services' },
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/process`, label: 'Our Process' },
  { href: `${base}/contact`, label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content={new URL('/images/untitled-design-56.png', Astro.site).href} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href={Astro.url.href} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <script async src="https://api.keithkelly.dev/d/s"></script>
  <script>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init({endpoint:"https://api.keithkelly.dev/d/e"})</script>
</head>
<body class="site-ab-brothers min-h-screen flex flex-col">

  <header class="sticky top-0 z-50 bg-background/95 backdrop-blur-sm border-b border-border">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 flex items-center justify-between h-16 md:h-18">
      <a href={`${base}/`} class="flex items-center gap-3 opacity-100">
        <img src="/images/ab-brothers-logo-black.png" alt="AB Brothers Construction Logo" class="h-10 md:h-12 w-auto" />
      </a>

      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium tracking-wide uppercase opacity-100',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-primary border-b-2 border-accent pb-0.5'
                : 'text-foreground/70 hover:text-foreground'
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href={`${base}/contact`}
          class="bg-accent text-white text-sm font-semibold px-5 py-2.5 rounded-full opacity-100 hover:bg-accent/90"
        >
          Free Quote
        </a>
      </nav>

      <button
        id="menu-toggle"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="block w-6 h-0.5 bg-foreground rounded-full" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-foreground rounded-full" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-foreground rounded-full" id="bar3"></span>
      </button>
    </div>

    <nav id="mobile-menu" class="hidden md:hidden border-t border-border bg-background">
      <div class="px-6 py-4 flex flex-col gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'py-3 text-sm font-medium tracking-wide uppercase border-b border-border/50 opacity-100',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-primary'
                : 'text-foreground/70'
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href={`${base}/contact`}
          class="mt-3 bg-accent text-white text-sm font-semibold px-5 py-3 rounded-full text-center opacity-100"
        >
          Free Quote
        </a>
      </div>
    </nav>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="bg-primary text-primary-foreground">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-16 md:py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
        <div>
          <img src="/images/ab-brothers-logo-white.png" alt="AB Brothers Construction" class="h-12 w-auto mb-5" />
          <p class="text-primary-foreground/70 text-sm leading-relaxed max-w-xs">
            Family-owned residential general contractor serving Pittsburgh's South Hills. Committed to craftsmanship and quality on every project.
          </p>
        </div>

        <div>
          <h3 class="text-sm font-semibold tracking-widest uppercase mb-5 text-primary-foreground">Contact</h3>
          <div class="space-y-3 text-sm text-primary-foreground/80">
            <div>
              <p class="text-primary-foreground/50 text-xs uppercase tracking-wider mb-1">Andy Hovanec</p>
              <a href="tel:4128551849" class="text-primary-foreground/80 opacity-100 hover:text-white">(412) 855-1849</a>
            </div>
            <div>
              <p class="text-primary-foreground/50 text-xs uppercase tracking-wider mb-1">Bob Krapp</p>
              <a href="tel:4126208821" class="text-primary-foreground/80 opacity-100 hover:text-white">(412) 620-8821</a>
            </div>
            <div class="pt-1">
              <a href="mailto:abconstruction412@yahoo.com" class="text-primary-foreground/80 opacity-100 hover:text-white">abconstruction412@yahoo.com</a>
            </div>
            <p class="text-primary-foreground/60 pt-1">Venetia, PA (South Hills of Pittsburgh)</p>
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold tracking-widest uppercase mb-5 text-primary-foreground">Navigate</h3>
          <div class="flex flex-col gap-2.5">
            {navLinks.map(link => (
              <a href={link.href} class="text-sm text-primary-foreground/70 opacity-100 hover:text-white">{link.label}</a>
            ))}
          </div>
          <div class="flex gap-4 mt-6">
            <a href="https://www.facebook.com/AB.BroConstruction/" target="_blank" rel="noopener noreferrer" class="text-primary-foreground/60 opacity-100 hover:text-white" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/andrew-hovanec-88b11231/" target="_blank" rel="noopener noreferrer" class="text-primary-foreground/60 opacity-100 hover:text-white" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="border-t border-primary-foreground/15 mt-12 pt-8 text-center">
        <p class="text-primary-foreground/50 text-xs">&copy; {new Date().getFullYear()} AB Brothers Construction, Inc. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');

    toggle?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isOpen));

      if (!isOpen) {
        bar1?.classList.add('rotate-45', 'translate-y-[4px]');
        bar2?.classList.add('opacity-0');
        bar3?.classList.add('-rotate-45', '-translate-y-[4px]');
      } else {
        bar1?.classList.remove('rotate-45', 'translate-y-[4px]');
        bar2?.classList.remove('opacity-0');
        bar3?.classList.remove('-rotate-45', '-translate-y-[4px]');
      }
    });
  </script>
</body>
</html>
